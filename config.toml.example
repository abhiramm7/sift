[storage]
# Folder under iCloud Drive where PDFs and per-paper derived files live.
# `paper init` creates `library/`, `inbox/`, and `user/` subfolders here.
icloud_root = "~/Library/Mobile Documents/com~apple~CloudDocs/PaperManager"

[claude]
# Used by the local `claude` CLI. Auth is whatever `claude login` set up.
model = "claude-sonnet-4-6"

[embed]
# Local embedder via Ollama. Run `ollama pull mxbai-embed-large` once.
# 1024-dim, 512-token context, no rate limits, fully local.
model = "mxbai-embed-large"
